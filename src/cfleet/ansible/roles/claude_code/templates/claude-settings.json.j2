{
  "model": "{{ claude_model }}",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "apiKeyHelper": "cat /home/{{ ssh_user }}/.claude/.api-key",
  "effortLevel": "high",
  "permissions": {
    "allow": ["Read", "Write", "Edit", "MultiEdit", "Bash(*)", "WebFetch"]
  }
}
