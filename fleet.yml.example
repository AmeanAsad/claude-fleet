# Local cfleet init config — copy to fleet.yml and fill in, then run `cfleet init`
#
#   cp fleet.yml.example fleet.yml
#   # edit fleet.yml with your values
#   cfleet init

anthropic_api_key: "sk-ant-..."

# cloud.provider sets the default for `cfleet spawn`.
# Options: devcontainer (local Docker), azure, gcp
# If omitted, `cfleet init` auto-detects: devcontainer if no cloud CLI is found.
#
# You can configure multiple providers and override per-worker with --provider:
#   cfleet spawn worker1                          # uses default provider
#   cfleet spawn worker2 --provider gcp           # uses gcp
#   cfleet spawn worker3 --provider devcontainer  # local container

# --- Local containers (no cloud needed, just Docker) ---
# cloud:
#   provider: devcontainer

# --- Cloud providers ---
# cloud:
#   provider: azure           # default provider
#   azure:
#     subscription_id: "your-azure-subscription-id"
#   gcp:
#     project_id: "your-gcp-project-id"
